# ── Frontend (local dev only — optional) ─────────────────────────────────────
# Leave empty in production; the app uses same-origin /api routes on Vercel.
# For local dev with Vite only: set to http://localhost:3000 while `vercel dev` runs.
VITE_API_BASE_URL=

# Vite dev-server proxy target (optional). Use http://localhost:3000 with `vercel dev`.
VITE_API_PROXY_TARGET=

# ── Contact form (serverless) ────────────────────────────────────────────────
# Optional: POST contact submissions to a webhook (Discord, Zapier, Make, etc.)
CONTACT_WEBHOOK_URL=

# Optional: Send contact form emails via Resend (https://resend.com)
RESEND_API_KEY=
CONTACT_EMAIL=hello@sazib.dev
RESEND_FROM_EMAIL=Portfolio <onboarding@resend.dev>
